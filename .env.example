# Host-side development config. Run `pnpm dev` / `pnpm worker:dev` (and
# `pnpm db:generate`) on the host, with the backing services exposed on
# localhost by `docker compose up -d database cache storage`.
#
# Copy this to `.env` and fill it in. The in-container app/worker use
# secrets/app/app.env instead — the same keys, but with service-name hosts.
NODE_ENV=development

# --- Google OAuth (read-only YouTube access) ---
# See the README "Get YouTube API credentials" section.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- App security (both mandatory) ---
# APP_ENCRYPTION_KEY encrypts the stored refresh token; must be >= 32 chars.
APP_ENCRYPTION_KEY=generate-a-strong-random-string-of-32+-chars
# APP_PASSWORD gates the whole app (it holds your token + private data).
APP_PASSWORD=choose-a-login-password

# --- Connection URLs (hosts point at the localhost-exposed compose ports) ---
# Credentials must match the database/cache/storage secrets.
DATABASE_URL=postgresql://app:change-me@localhost:5432/youtube_search
CACHE_URL=redis://app:change-me@localhost:6379
STORAGE_URL=s3://change-me:change-me@localhost:8333/youtube-search?region=us-east-1

# --- Non-secret tunables ---
RESYNC_STALE_AFTER_DAYS=30
