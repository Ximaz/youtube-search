# App + worker configuration (compose services: app, worker).

# --- Google OAuth (read-only YouTube access) ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials,
# enable "YouTube Data API v3", make an OAuth client of type "Web application",
# and add OAUTH_REDIRECT_URI as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- App security (both mandatory) ---
# APP_ENCRYPTION_KEY encrypts the stored refresh token; must be >= 32 chars.
APP_ENCRYPTION_KEY=generate-a-strong-random-string-of-32+-chars
# APP_PASSWORD gates the whole app (it holds your token + private data).
APP_PASSWORD=choose-a-login-password

# --- Connection URLs (host parts match compose service names) ---
# Credentials must match the database/cache/storage secrets.
DATABASE_URL=postgresql://app:change-me@database:5432/youtube_search
CACHE_URL=redis://app:change-me@cache:6379
STORAGE_URL=s3://change-me:change-me@storage:8333/youtube-search?region=us-east-1

# --- Non-secret tunables ---
RESYNC_STALE_AFTER_DAYS=30
NODE_ENV=production
